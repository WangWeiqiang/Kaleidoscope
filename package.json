{
  "name": "kaleidoscope",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "assets": "node scripts/generate-assets.mjs",
    "fragments": "node scripts/build-fragments.mjs",
    "fragments:samples": "node scripts/make-sample-fragments.mjs && node scripts/build-fragments.mjs",
    "check:shader": "node scripts/check-shader.mjs",
    "preview": "node scripts/render-fragments.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "@shopify/react-native-skia": "1.5.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-haptics": "~14.0.0",
    "expo-screen-orientation": "~8.0.0",
    "expo-sensors": "~14.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "canvaskit-wasm": "0.39.1",
    "typescript": "~5.3.3"
  },
  "private": true
}
